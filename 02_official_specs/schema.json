{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Country Flag Specification",
  "type": "object",
  "properties": {
    "iso_alpha2": {
      "type": "string",
      "description": "ISO 3166-1 alpha-2 country code"
    },
    "name_en": {
      "type": "string"
    },
    "name_ja": {
      "type": "string"
    },
    "ratio": {
      "type": "string",
      "description": "Official proportion (e.g. 2:3, 1:2)"
    },
    "specs_source": {
      "type": "string",
      "description": "The official or primary source for the specification"
    },
    "colors_extracted": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "color_name": {"type": "string"},
          "hex": {"type": "string"},
          "rgb": {"type": "string"},
          "cmyk": {"type": "string"},
          "pantone": {"type": "string"}
        }
      }
    },
    "notes": {
      "type": "string",
      "description": "Any additional construction notes or exceptions"
    }
  },
  "required": ["iso_alpha2", "name_en"]
}
